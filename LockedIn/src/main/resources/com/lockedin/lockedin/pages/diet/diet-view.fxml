<?xml version="1.0" encoding="UTF-8"?>

<!-- FXML file to manage diet-page layout - I've initialized it as GridPane - feel free to change it -->
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.StackPane?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.lockedin.lockedin.controller.diet.DietController">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER">

        <VBox spacing="12" alignment="TOP_LEFT" style="-fx-padding: 20;">

            <Label text="Nutrition Tracker" style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <TextField fx:id="foodField" promptText="Food Name"            />
            <TextField fx:id="caloriesField" promptText="Calories"         />
            <TextField fx:id="proteinField" promptText="Protein"       />
            <TextField fx:id="carbsField" promptText="Carbs"           />
            <TextField fx:id="fatsField" promptText="Fats"             />

            <HBox spacing="10">
                <Button text="Add Food" onAction="#handleAddFood"          />
                <Button text="Reset" onAction="#handleReset"               />
                <Button text="Remove Food" onAction="#handleRemoveFood" />
                <Label text="Goals" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 0 0 0 40;"  />
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <ProgressBar fx:id="caloriesProgressBar" prefWidth="250" minHeight="25" styleClass="diet-progress-bar" />
                <Label fx:id="caloriesProgressLabel" style="-fx-font-size: 14px;" />
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ProgressBar fx:id="proteinProgressBar" prefWidth="250" minHeight="25" styleClass="diet-progress-bar" />
                <Label fx:id="proteinProgressLabel" style="-fx-font-size: 14px;" />
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ProgressBar fx:id="carbsProgressBar" prefWidth="250" minHeight="25" styleClass="diet-progress-bar" />
                <Label fx:id="carbsProgressLabel" style="-fx-font-size: 14px;" />
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ProgressBar fx:id="fatProgressBar" prefWidth="250" minHeight="25" styleClass="diet-progress-bar" />
                <Label fx:id="fatsProgressLabel" style="-fx-font-size: 14px;" />
            </HBox>

            <ListView fx:id="foodList" prefHeight="300"                   />

        </VBox>
    </ScrollPane>
</StackPane>
