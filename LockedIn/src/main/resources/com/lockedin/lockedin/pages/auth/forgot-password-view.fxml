<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true"
            fx:controller="com.lockedin.lockedin.controller.auth.ForgotPasswordController"
            stylesheets="@../../style/style.css"
            styleClass="diet-scroll">
    <VBox alignment="TOP_LEFT"
          spacing="12.0"
          prefWidth="400.0"
          prefHeight="700.0"
          style="-fx-padding: 30; -fx-background-color: #F0F2F5;">
        <HBox alignment="CENTER_LEFT"
              maxWidth="Infinity">
            <ImageView fx:id="backImageView"
                       preserveRatio="true"
                       fitHeight="50"
                       pickOnBounds="true"
                       style="-fx-cursor: hand;"
                       onMouseClicked="#handleBackButton">
                <image>
                    <Image url="@../../images/back_arrow.png"/>
                </image>
            </ImageView>
        </HBox>
        <Label text="Forgot Password"
               styleClass="diet-section-title"/>
        <Label text="Enter the email linked to your account and we'll send you a one-time code."
               wrapText="true"
               styleClass="auth-form-tagline"/>
        <Label fx:id="emailLabel"
               text="Email"
               styleClass="profile-detail-label"/>
        <TextField fx:id="emailField"
                   promptText="Enter your email"
                   styleClass="diet-input"/>
        <PasswordField fx:id="passwordField"
                       promptText="Enter your new password here"
                       managed="false"
                       visible="false"
                       styleClass="diet-input"/>
        <Label fx:id="confirmPasswordLabel"
               text="Confirm Password"
               managed="false"
               visible="false"
               styleClass="profile-detail-label"/>
        <PasswordField fx:id="confirmPasswordField"
                       promptText="Confirm your new password"
                       managed="false"
                       visible="false"
                       styleClass="diet-input"/>
        <HBox alignment="CENTER_RIGHT"
              maxWidth="Infinity">
            <Button fx:id="getOtpBtn"
                    text="Get OTP"
                    onAction="#handleGetOtp"
                    styleClass="primary-btn"/>
        </HBox>
    </VBox>
</ScrollPane>
