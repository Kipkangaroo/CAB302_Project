<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      alignment="TOP_CENTER"
      spacing="16.0"
      fx:controller="com.lockedin.lockedin.controller.auth.LogInController"
      stylesheets="@../../style/style.css"
      prefWidth="400.0"
      prefHeight="650.0"
      style="-fx-padding: 28 34 28 34; -fx-background-color: #F0F2F5;">
    <ImageView preserveRatio="true"
               fitHeight="100">
        <image>
            <Image url="@../../graphics/images/logo.png"/>
        </image>
    </ImageView>
    <Label text="Train hard. Stay focused. Unlock your best self."
           styleClass="auth-form-tagline">
        <VBox.margin>
            <Insets top="4"/>
        </VBox.margin>
    </Label>
    <HBox alignment="CENTER"
          maxWidth="Infinity">
        <VBox.margin>
            <Insets top="4"/>
        </VBox.margin>
        <VBox alignment="TOP_LEFT"
              spacing="11.0"
              prefWidth="260.0"
              maxWidth="260.0">
            <Label text="Email"
                   styleClass="profile-detail-label"/>
            <TextField fx:id="emailField"
                       promptText="Enter your email"
                       styleClass="diet-input"
                       maxWidth="Infinity"/>
            <Label text="Password"
                   styleClass="profile-detail-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           styleClass="diet-input"
                           maxWidth="Infinity"/>
            <HBox alignment="CENTER_RIGHT"
                  maxWidth="Infinity">
                <Hyperlink fx:id="forgotPasswordLink"
                           text="Forgot your password?"
                           onAction="#handleForgotPassword"/>
            </HBox>
            <Button fx:id="loginBtn"
                    text="Log In"
                    onAction="#handleLogIn"
                    styleClass="primary-btn"
                    maxWidth="Infinity"/>
        </VBox>
    </HBox>
    <Region VBox.vgrow="ALWAYS"
            minHeight="24.0"/>
    <ImageView preserveRatio="true"
               fitHeight="220">
        <image>
            <Image url="@../../graphics/images/app-features.png"/>
        </image>
        <VBox.margin>
            <Insets top="4"/>
        </VBox.margin>
    </ImageView>
    <HBox alignment="CENTER"
          spacing="8.0">
        <VBox.margin>
            <Insets top="8" bottom="6"/>
        </VBox.margin>
        <Label text="Don't have an account?"
               styleClass="profile-detail-label"/>
        <Hyperlink text="Signup!"
                   onAction="#handleSignup"/>
    </HBox>
</VBox>