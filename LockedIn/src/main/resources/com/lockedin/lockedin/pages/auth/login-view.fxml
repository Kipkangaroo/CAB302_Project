<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="8.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lockedin.lockedin.controller.auth.LogInController"
      prefWidth="400.0" prefHeight="650.0" style="-fx-padding: 20 30 20 30;">
    <ImageView preserveRatio="true" fitHeight="130">
        <image>
            <Image url="@../../images/logo.png" />
        </image>
    </ImageView>
    <Label text="Train hard. Stay focused. Unlock your best self."
           style="-fx-font-size: 14; -fx-text-fill: black; -fx-font-weight: bold;" />

    <Label text="Email" />
    <TextField fx:id="emailField" promptText="Enter your email" maxWidth="260.0" />

    <Label text="Password" />
    <PasswordField fx:id="passwordField" promptText="Enter your password" maxWidth="260.0" />

    <Button fx:id="loginBtn" text="Log In" onAction="#handleLogIn" maxWidth="260.0" />

    <Region VBox.vgrow="ALWAYS" />
    <ImageView preserveRatio="true" fitHeight="210">
        <image>
            <Image url="@../../images/app_features.png" />
        </image>
    </ImageView>

    <HBox alignment="CENTER" spacing="4.0">
        <Label text="Don't have an account?" />
        <Hyperlink text="Signup!" onAction="#handleSignup" />
    </HBox>
</VBox>
