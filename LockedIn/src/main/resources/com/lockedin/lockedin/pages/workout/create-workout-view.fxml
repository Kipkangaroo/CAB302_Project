<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.controlsfx.control.SearchableComboBox?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lockedin.lockedin.controller.workout.CreateWorkoutController"
      fillWidth="true"
      maxWidth="Infinity"
      maxHeight="Infinity">

    <!-- ── Gradient header ── -->
    <VBox styleClass="workout-header" fillWidth="true">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Button fx:id="backButton" text="&#x2190;" styleClass="header-btn"
                    onAction="#handleBack"
                    style="-fx-font-size: 16px;"/>
            <Label text="Create Workout" textFill="white"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <!-- ── Form body ── -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="workout-scroll"
                hbarPolicy="NEVER">
        <VBox styleClass="workout-page-bg" spacing="14" fillWidth="true">

            <!-- Name + notes card -->
            <VBox styleClass="workout-card" spacing="10">
                <Label text="Workout Details"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <TextField fx:id="workoutNameField"
                           promptText="Workout name  (e.g. Push Day A)"
                           maxWidth="Infinity"/>
                <TextField fx:id="workoutNotesField"
                           promptText="Short description  (optional)"
                           maxWidth="Infinity"/>
            </VBox>

            <!-- Add exercise card -->
            <VBox styleClass="workout-card" spacing="10">
                <Label text="Add Exercise"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <SearchableComboBox fx:id="exerciseCombo"
                                    promptText="Search exercises..."
                                    maxWidth="Infinity"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Sets:" style="-fx-text-fill: #555;"/>
                    <TextField fx:id="setsField" prefWidth="55" maxWidth="55"
                               style="-fx-alignment: center;"/>
                    <Label text="Reps:" style="-fx-text-fill: #555;"/>
                    <TextField fx:id="repsField" prefWidth="55" maxWidth="55"
                               style="-fx-alignment: center;"/>
                    <Label text="Rest (s):" style="-fx-text-fill: #555;"/>
                    <TextField fx:id="restField" prefWidth="55" maxWidth="55"
                               style="-fx-alignment: center;"/>
                </HBox>
                <Button text="+ Add Exercise" onAction="#handleAddExercise"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1565C0; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 8;
                               -fx-padding: 8 0 8 0; -fx-cursor: hand;"/>
            </VBox>

            <!-- Exercise list card -->
            <VBox styleClass="workout-card" spacing="8">
                <Label text="Exercises in this workout"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <ListView fx:id="exerciseList" prefHeight="180" maxWidth="Infinity"
                          style="-fx-border-color: transparent;"/>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- ── Save button ── -->
    <HBox style="-fx-padding: 10 16 14 16;">
        <Button text="Save Workout" onAction="#handleSave"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"
                styleClass="primary-btn"
                style="-fx-padding: 14 0 14 0;"/>
    </HBox>
</VBox>
