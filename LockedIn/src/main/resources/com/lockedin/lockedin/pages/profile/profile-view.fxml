<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx" fx:controller="com.lockedin.lockedin.controller.profile.ProfileController"
      maxWidth="Infinity" maxHeight="Infinity">
    <VBox styleClass="profile-header">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Label text="My Profile" styleClass="profile-header-title"
                   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="📊"
                    onAction="#handleGoalsProgress"
                    styleClass="header-btn"
                    style="-fx-font-size: 16px;"/>
        </HBox>
        <Label text="Your personal details and weekly streak" styleClass="profile-header-subtitle">
            <VBox.margin>
                <Insets top="4"/>
            </VBox.margin>
        </Label>
    </VBox>
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="profile-scroll" hbarPolicy="NEVER">
        <VBox styleClass="profile-page-bg" spacing="12">
            <VBox styleClass="profile-card" alignment="CENTER" spacing="8" maxWidth="Infinity">
                <StackPane styleClass="profile-avatar-stack" maxWidth="200" maxHeight="150">
                    <ImageView fx:id="imageView" fitHeight="150" fitWidth="200" preserveRatio="true">
                        <Image url="@../../graphics/images/profileimage.png"/>
                    </ImageView>
                </StackPane>
                <Label fx:id="firstNameLabel" styleClass="profile-name-label" alignment="CENTER"/>
            </VBox>
            <StackPane maxWidth="Infinity">
                <VBox styleClass="profile-card" spacing="8" maxWidth="Infinity">
                    <Label text="Personal Information" styleClass="profile-section-title"/>
                    <Label fx:id="ageLabel" styleClass="profile-detail-label"/>
                    <Label fx:id="heightLabel" styleClass="profile-detail-label"/>
                    <TextField fx:id="weightField" editable="false" focusTraversable="false"
                               styleClass="profile-detail-field" maxWidth="Infinity"/>
                    <Label fx:id="fitnessGoalLabel" styleClass="profile-detail-label" maxWidth="Infinity"/>
                    <ComboBox fx:id="fitnessGoalCombo" focusTraversable="false"
                              styleClass="profile-goal-combo" maxWidth="Infinity"
                              visible="false" managed="false"/>
                </VBox>
                <StackPane alignment="TOP_RIGHT" pickOnBounds="false">
                    <ImageView fx:id="editActionIcon" fitWidth="48" fitHeight="48" preserveRatio="true"
                               pickOnBounds="true" styleClass="profile-edit-icon" onMouseClicked="#handleEditDetails">
                        <StackPane.margin>
                            <Insets top="6" right="6"/>
                        </StackPane.margin>
                        <Image url="@../../graphics/icons/edit-icon.png"/>
                    </ImageView>
                </StackPane>
            </StackPane>
            <VBox styleClass="profile-card" spacing="8">
                <Label text="Calorie Tracking Streak (Last 7 Days)" styleClass="profile-section-title"/>
                <HBox fx:id="calorieStreakRow" alignment="CENTER" spacing="6">
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <VBox styleClass="profile-card" spacing="8">
                <Label text="Workout Tracking Streak (Last 7 Days)" styleClass="profile-section-title"/>
                <HBox fx:id="workoutStreakRow" alignment="CENTER" spacing="6">
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                    <VBox alignment="CENTER" minWidth="30">
                        <Circle radius="10" stroke="BLACK" strokeType="INSIDE"/>
                        <Label styleClass="profile-day-label"/>
                    </VBox>
                </HBox>
            </VBox>
            <!-- Measurement Tracking Section -->
            <VBox styleClass="profile-card" spacing="12">
                <Label text="Weight Progress (Last 30 Days)" styleClass="profile-section-title"/>
                <LineChart fx:id="weightChart"
                           styleClass="profile-weight-chart"
                           prefHeight="260"
                           animated="false"
                           legendVisible="false"
                           createSymbols="false">
                    <xAxis>
                        <CategoryAxis label="Date" side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Body Weight (kg)"
                                    side="LEFT"
                                    minorTickVisible="false"
                                    forceZeroInRange="false"
                                    autoRanging="true"/>
                    </yAxis>
                </LineChart>
            </VBox>
        </VBox>
    </ScrollPane>
    <HBox style="-fx-padding: 10 16 14 16;">
        <Button fx:id="logoutBtn" mnemonicParsing="false" onAction="#handleLogout" text="Log Out"
                styleClass="primary-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-padding: 14 0 14 0;"/>
        <ImageView fx:id="deleteAccountIcon" fitWidth="32" fitHeight="32" preserveRatio="true"
                   pickOnBounds="true" styleClass="profile-delete-icon" onMouseClicked="#handleDeleteAccount">
            <HBox.margin>
                <Insets top="6" left="12"/>
            </HBox.margin>
            <Image url="@../../graphics/icons/bin-icon.png"/>
        </ImageView>
    </HBox>
</VBox>