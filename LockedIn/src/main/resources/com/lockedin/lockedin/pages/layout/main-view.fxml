<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.lockedin.lockedin.controller.layout.LayoutController"
            stylesheets="@../../style/style.css">
    <center>
        <!-- main "container" for the page - this changes to the different pages according to button presses -->
        <StackPane fx:id="pageContainer"/>
    </center>
    <bottom>
        <!-- layout for bottom nav -->
        <HBox alignment="CENTER"
              spacing="100"
              styleClass="nav-bar">
            <Button fx:id="workoutNavButton"
                    onAction="#showWorkoutPage"
                    styleClass="nav-btn"
                    HBox.hgrow="ALWAYS"
                    minWidth="42"
                    maxWidth="42">
                <graphic>
                    <ImageView fitWidth="42"
                               fitHeight="42"
                               preserveRatio="true">
                        <Image url="@../../graphics/icons/workout-icon.png"/>
                    </ImageView>
                </graphic>
            </Button>
            <Button fx:id="dietNavButton"
                    onAction="#showDietPage"
                    styleClass="nav-btn"
                    HBox.hgrow="ALWAYS"
                    minWidth="42"
                    maxWidth="42">
                <graphic>
                    <ImageView fitWidth="42"
                               fitHeight="42"
                               preserveRatio="true">
                        <Image url="@../../graphics/icons/diet-icon.png"/>
                    </ImageView>
                </graphic>
            </Button>
            <Button fx:id="profileNavButton"
                    onAction="#showProfilePage"
                    styleClass="nav-btn"
                    HBox.hgrow="ALWAYS"
                    minWidth="42"
                    maxWidth="42">
                <graphic>
                    <ImageView fitWidth="42"
                               fitHeight="42"
                               preserveRatio="true">
                        <Image url="@../../graphics/icons/profile-icon.png"/>
                    </ImageView>
                </graphic>
            </Button>
        </HBox>
    </bottom>
</BorderPane>