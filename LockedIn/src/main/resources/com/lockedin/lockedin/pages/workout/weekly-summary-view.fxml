<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      xmlns="http://javafx.com/javafx"
      fx:controller="com.lockedin.lockedin.controller.workout.WeeklySummaryController"
      fillWidth="true"
      maxWidth="Infinity"
      maxHeight="Infinity">

    <!-- ── Gradient header ── -->
    <VBox styleClass="workout-header" fillWidth="true">
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Button fx:id="backButton"
                    text="←"
                    styleClass="header-btn"
                    onAction="#handleBack"
                    style="-fx-font-size: 16px;"/>
            <Label text="Weekly Summary"
                   textFill="white"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"
                   HBox.hgrow="ALWAYS"
                   maxWidth="Infinity"/>
        </HBox>

        <!-- Week navigation -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <VBox.margin>
                <Insets top="6"/>
            </VBox.margin>
            <Button text="‹"
                    styleClass="header-btn"
                    onAction="#handlePrevWeek"
                    style="-fx-font-size: 18px;"/>
            <Label fx:id="weekRangeLabel"
                   textFill="white"
                   style="-fx-font-size: 13px; -fx-opacity: 0.9;"
                   HBox.hgrow="ALWAYS"
                   maxWidth="Infinity"/>
            <Button text="›"
                    styleClass="header-btn"
                    onAction="#handleNextWeek"
                    style="-fx-font-size: 18px;"/>
        </HBox>
    </VBox>

    <!-- ── Scrollable content ── -->
    <ScrollPane VBox.vgrow="ALWAYS"
                fitToWidth="true"
                hbarPolicy="NEVER"
                styleClass="workout-scroll">
        <VBox styleClass="workout-page-bg" spacing="14" fillWidth="true">

            <!-- Stats row -->
            <HBox spacing="10" fillHeight="true">
                <VBox styleClass="workout-card"
                      alignment="CENTER"
                      HBox.hgrow="ALWAYS"
                      spacing="4">
                    <Label fx:id="sessionsValue"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #028ee1;"
                           text="0"/>
                    <Label text="Sessions"
                           style="-fx-font-size: 12px; -fx-text-fill: #65758a;"/>
                </VBox>
                <VBox styleClass="workout-card"
                      alignment="CENTER"
                      HBox.hgrow="ALWAYS"
                      spacing="4">
                    <Label fx:id="setsValue"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #028ee1;"
                           text="0"/>
                    <Label text="Total Sets"
                           style="-fx-font-size: 12px; -fx-text-fill: #65758a;"/>
                </VBox>
                <VBox styleClass="workout-card"
                      alignment="CENTER"
                      HBox.hgrow="ALWAYS"
                      spacing="4">
                    <Label fx:id="activeDaysValue"
                           style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #028ee1;"
                           text="0"/>
                    <Label text="Active Days"
                           style="-fx-font-size: 12px; -fx-text-fill: #65758a;"/>
                </VBox>
            </HBox>

            <!-- Individual workout cards for this week -->
            <VBox fx:id="workoutsContainer" spacing="10" fillWidth="true"/>

        </VBox>
    </ScrollPane>
</VBox>
