<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fitToWidth="true"
            fx:controller="com.lockedin.lockedin.controller.auth.SignUpController"
            stylesheets="@../../style/style.css"
            styleClass="diet-scroll">
    <VBox xmlns:fx="http://javafx.com/fxml"
          alignment="TOP_LEFT"
          spacing="12.0"
          prefWidth="400.0"
          prefHeight="700.0"
          style="-fx-padding: 30; -fx-background-color: #F0F2F5;">
        <HBox alignment="CENTER_LEFT"
              maxWidth="Infinity">
            <ImageView fx:id="logoImageView"
                       preserveRatio="true"
                       fitHeight="50"
                       pickOnBounds="true"
                       style="-fx-cursor: hand;"
                       onMouseClicked="#handleBackButton">
                <image>
                    <Image url="@../../graphics/icons/back-arrow-icon.png"/>
                </image>
            </ImageView>
        </HBox>
        <Label text="Sign Up"
               styleClass="diet-section-title"/>
        <Label text="First Name"
               styleClass="profile-detail-label"/>
        <TextField fx:id="firstNameField"
                   promptText="Enter your first name"
                   styleClass="diet-input"/>
        <Label text="Last Name"
               styleClass="profile-detail-label"/>
        <TextField fx:id="lastNameField"
                   promptText="Enter your last name"
                   styleClass="diet-input"/>
        <Label text="Email"
               styleClass="profile-detail-label"/>
        <TextField fx:id="emailField"
                   promptText="Enter your email"
                   styleClass="diet-input"/>
        <Label text="Password"
               styleClass="profile-detail-label"/>
        <PasswordField fx:id="passwordField"
                       promptText="Enter your password"
                       styleClass="diet-input"/>
        <Label text="Confirm Password"
               styleClass="profile-detail-label"/>
        <PasswordField fx:id="confirmPasswordField"
                       promptText="Confirm your password"
                       styleClass="diet-input"/>
        <Label text="Date of Birth"
               styleClass="profile-detail-label"/>
        <DatePicker fx:id="dobPicker"
                    promptText="Select your date of birth"
                    styleClass="diet-input"
                    maxWidth="Infinity"/>
        <Label text="Height (cm)"
               styleClass="profile-detail-label"/>
        <TextField fx:id="heightField"
                   promptText="Enter your height in cm"
                   styleClass="diet-input"/>
        <Label text="Weight (kg)"
               styleClass="profile-detail-label"/>
        <TextField fx:id="weightField"
                   promptText="Enter your weight in kg"
                   styleClass="diet-input"/>
        <Label text="Sex"
               styleClass="profile-detail-label"/>
        <ComboBox fx:id="sexCombo"
                  promptText="Select your sex"
                  styleClass="diet-input"
                  maxWidth="Infinity"/>
        <Label text="Activity Level"
               styleClass="profile-detail-label"/>
        <ComboBox fx:id="activityLevelCombo"
                  promptText="Select your activity level"
                  styleClass="diet-input"
                  maxWidth="Infinity"/>
        <Label text="Fitness Goal"
               styleClass="profile-detail-label"/>
        <ComboBox fx:id="fitnessGoalCombo"
                  promptText="Select your fitness goal"
                  styleClass="diet-input"
                  maxWidth="Infinity"/>
        <HBox alignment="CENTER_RIGHT"
              maxWidth="Infinity">
            <Button fx:id="signupBtn"
                    text="Sign Up"
                    onAction="#handleSignup"
                    styleClass="primary-btn"/>
        </HBox>
    </VBox>
</ScrollPane>