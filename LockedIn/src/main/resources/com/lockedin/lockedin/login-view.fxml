<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Button?>

<!-- FXML file to manage login-page layout - I've initialized it as GridPane - feel free to change it -->

<GridPane hgap="12" vgap="8" xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.lockedin.lockedin.controller.LogInController">
    <Label text="LOG IN PAGE" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <Button fx:id="loginBtn" text="Press to Log in" GridPane.rowIndex="1" GridPane.columnIndex="0" onAction="#handleLogIn"/>
</GridPane>
