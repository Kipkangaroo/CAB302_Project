<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="12.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lockedin.lockedin.controller.auth.LogInController"
      prefWidth="400.0" prefHeight="500.0" style="-fx-padding: 30;">
    <Label text="Locked In" style="-fx-font-size: 30; -fx-font-weight: bold;" />
    <Label text="Train hard. Stay focused. Unlock your best self."
           style="-fx-font-size: 14; -fx-text-fill: black;" />

    <Label text="Email" />
    <TextField fx:id="emailField" promptText="Enter your email" maxWidth="260.0" />

    <Label text="Password" />
    <PasswordField fx:id="passwordField" promptText="Enter your password" maxWidth="260.0" />

    <Button fx:id="loginBtn" text="Log In" onAction="#handleLogIn" maxWidth="260.0" />

    <Region VBox.vgrow="ALWAYS" />
    <HBox alignment="CENTER" spacing="4.0">
        <Label text="Don't have an account?" />
        <Hyperlink text="Signup!" onAction="#handleSignup" />
    </HBox>
</VBox>
