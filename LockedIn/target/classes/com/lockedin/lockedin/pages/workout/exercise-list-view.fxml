<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import org.controlsfx.control.SearchableComboBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lockedin.lockedin.controller.workout.ExerciseViewController"
      spacing="12">

    <HBox spacing="12">
        <Button fx:id="backButton" text="Back" onAction="#handleBackButton"/>
        <SearchableComboBox fx:id="exerciseSearch"
                            promptText="Search exercises..."
                            HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                VBox.vgrow="ALWAYS"
                fx:id="exerciseDetails">
        <VBox spacing="8">
            <GridPane>
                <Label text="Exercise:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="exerciseName" text="Squat" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Primary Muscles:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="primaryMuscle" text="Quads" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Instructions:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="instructions" text="do xyz" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Form Guide:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            </GridPane>
            <ImageView fitWidth="300" fitHeight="300" preserveRatio="true">
                <Image url="https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/Air_Bike/0.jpg"/>
            </ImageView>
            <ImageView fitWidth="300" fitHeight="300" preserveRatio="true">
                <Image url="https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/Air_Bike/0.jpg"/>
            </ImageView>
        </VBox>
    </ScrollPane>
</VBox>
