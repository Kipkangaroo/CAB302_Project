<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>

<BorderPane
        xmlns:fx="http://javafx.com/fxml" fx:controller="com.lockedin.lockedin.MainController"
        stylesheets="@style/style.css">
    <center>
        <!-- main "container" for the page - this changes to the different pages according to button presses -->
        <StackPane fx:id="pageContainer"/>
    </center>
    <bottom>
        <!-- layout for bottom nav-->
        <HBox alignment="CENTER">
            <Button fx:id="btnWorkout" text="Workout" onAction="#showWorkoutPage"
                    styleClass="nav-btn"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="btnDiet" text="Diet" onAction="#showDietPage"
                    styleClass="nav-btn"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button fx:id="btnProfile" text="Profile" onAction="#showProfilePage"
                    styleClass="nav-btn"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>
    </bottom>
</BorderPane>